@article{KNMJ+17,
	abstract = {In general, most elections follow the principle of equality, or as it came to be known, the principle of ``one person -- one vote''. However, this principle might pose difficulties for voters, who are not well informed regarding the particular matter that is voted on. In order to address this issue, a new form of voting has been proposed, namely proxy voting. In proxy voting, each voter has the possibility to delegate her voting right to another voter, so called proxy, that she considers a trusted expert on the matter. In this paper we propose an end-to-end verifiable Internet voting scheme, which to the best of our knowledge is the first scheme to address voter coercion in the proxy voting setting.},
	author = {Oksana Kulyk and Stephan Neumann and Karola Marky and Jurlind Budurushi and Melanie Volkamer},
	date-added = {2021-03-23 10:14:29 -0400},
	date-modified = {2021-03-23 10:14:29 -0400},
	journal = {Computers & Security},
	title = {Coercion-resistant proxy voting},
	volume = {71},
	year = {2017},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/S0167404817301268},
	bdsk-url-2 = {https://doi.org/10.1016/j.cose.2017.06.007}}

